# PaperClaw v0.01 OpenAI-compatible model adapter
# Copy to .env only for local use. Never commit real credentials.
PAPERCLAW_API_KEY=YOUR_API_KEY
PAPERCLAW_BASE_URL=https://api.example.com/v1
PAPERCLAW_MODEL=YOUR_MODEL_NAME

# Live CLI/TUI calls retry transient provider connection failures by default.
PAPERCLAW_PROVIDER_MAX_ATTEMPTS=3
PAPERCLAW_PROVIDER_BACKOFF_SECONDS=0.5
PAPERCLAW_PROVIDER_MAX_BACKOFF_SECONDS=8
